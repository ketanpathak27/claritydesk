<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ClarityDesk</title>
  <meta name="theme-color" content="#7c3aed">
  <meta name="description" content="Turn messy notes into organized action items, plans, summaries, and exports.">
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="icon" href="icons/claritydesk-icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="icons/claritydesk-icon.svg">
  <style>
    :root {
      --ink: #111827;
      --muted: #64748b;
      --line: #dbe3ee;
      --paper: #ffffff;
      --soft: #f7f9fc;
      --soft-2: #eef4f8;
      --accent: #7c3aed;
      --accent-dark: #5b21b6;
      --accent-soft: #ede9fe;
      --accent-glow: rgba(124, 58, 237, 0.34);
      --gold: #b7791f;
      --red: #b42318;
      --green: #247a4d;
      --blue: #2563eb;
      --shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      color: var(--ink);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at 10% 0%, rgba(124, 58, 237, 0.2), transparent 28rem),
        radial-gradient(circle at 90% 5%, rgba(168, 85, 247, 0.14), transparent 24rem),
        linear-gradient(180deg, #f8fbfd 0%, #edf3f7 100%);
      min-height: 100vh;
    }

    button, input, textarea, select {
      font: inherit;
    }

    button {
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--ink);
      background: var(--paper);
      padding: 10px 13px;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;
    }

    button:hover {
      transform: translateY(-1px);
      border-color: #9fb2c5;
    }

    button.primary {
      color: white;
      border-color: var(--accent);
      background: var(--accent);
    }

    button.primary:hover {
      background: var(--accent-dark);
    }

    button.subtle {
      background: rgba(255, 255, 255, 0.72);
    }

    button.danger {
      color: var(--red);
      border-color: #f1b5ae;
      background: #fff7f5;
    }

    .shell {
      width: min(1480px, 100%);
      margin: 0 auto;
      padding: 18px 22px 28px;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 5;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 14px 0;
      backdrop-filter: blur(12px);
    }

    .brand {
      display: flex;
      gap: 12px;
      align-items: center;
      min-width: 220px;
    }

    .mark {
      display: grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border-radius: 8px;
      color: white;
      background: linear-gradient(135deg, #8b5cf6, #5b21b6);
      box-shadow: 0 10px 28px rgba(124, 58, 237, 0.32);
      font-weight: 900;
    }

    .brand h1 {
      margin: 0;
      font-size: 22px;
      line-height: 1;
      letter-spacing: 0;
    }

    .brand span {
      display: block;
      margin-top: 4px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    .nav {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav button {
      padding: 9px 12px;
      color: #334155;
      background: rgba(255, 255, 255, 0.64);
    }

    .nav button.active {
      color: white;
      border-color: var(--accent);
      background: var(--accent);
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(340px, 0.9fr);
      gap: 18px;
      align-items: stretch;
      margin: 10px 0 18px;
    }

    .hero-panel {
      border: 1px solid rgba(219, 227, 238, 0.9);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero-copy {
      padding: 26px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      padding: 7px 10px;
      border-radius: 999px;
      color: #4c1d95;
      background: #ede9fe;
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .hero h2 {
      margin: 0;
      max-width: 760px;
      font-size: clamp(34px, 5vw, 66px);
      line-height: 0.98;
      letter-spacing: 0;
    }

    .hero p {
      max-width: 820px;
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.55;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 22px;
    }

    .stat {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 13px;
      background: var(--soft);
    }

    .stat strong {
      display: block;
      font-size: 28px;
      line-height: 1;
    }

    .stat span {
      display: block;
      margin-top: 6px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .project-box {
      padding: 18px;
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .field {
      display: grid;
      gap: 7px;
    }

    label {
      color: #334155;
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    input, select, textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--ink);
      background: white;
      outline: 0;
    }

    input, select {
      padding: 10px 12px;
    }

    textarea {
      min-height: 410px;
      resize: vertical;
      padding: 16px;
      font: 15px/1.55 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.13);
    }

    .view {
      display: none;
    }

    .view.active {
      display: block;
    }

    .grid {
      display: grid;
      grid-template-columns: minmax(320px, 0.9fr) minmax(360px, 1.1fr);
      gap: 18px;
      align-items: start;
    }

    .panel {
      border: 1px solid rgba(219, 227, 238, 0.9);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.86);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      background: rgba(247, 249, 252, 0.9);
    }

    .panel-title {
      margin: 0;
      color: #334155;
      font-size: 14px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .counter {
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .panel-body {
      padding: 16px;
    }

    .results {
      min-height: 410px;
    }

    .summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 14px;
    }

    .group {
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
      margin-top: 12px;
      background: white;
    }

    .group h3 {
      margin: 0;
      padding: 12px 14px;
      font-size: 16px;
      background: #f8fafc;
      border-bottom: 1px solid var(--line);
    }

    .item {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 11px;
      align-items: start;
      padding: 13px 14px;
      border-bottom: 1px solid var(--line);
    }

    .item:last-child {
      border-bottom: 0;
    }

    .check {
      width: 22px;
      height: 22px;
      border: 2px solid #77b7b1;
      border-radius: 6px;
      margin-top: 1px;
      appearance: none;
      cursor: pointer;
    }

    .check:checked {
      background: var(--accent);
      border-color: var(--accent);
      box-shadow: inset 0 0 0 4px white;
    }

    .task-title {
      margin: 0;
      font-weight: 900;
      line-height: 1.35;
    }

    .task-note {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.35;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      justify-content: flex-end;
      max-width: 230px;
    }

    .pill {
      border-radius: 999px;
      padding: 5px 8px;
      font-size: 12px;
      font-weight: 900;
      background: #eef5f8;
      color: #24586b;
      white-space: nowrap;
    }

    .pill.high {
      color: #8a241d;
      background: #fde9e7;
    }

    .pill.medium {
      color: #744210;
      background: #fff3d6;
    }

    .pill.low {
      color: #276749;
      background: #ddf5e8;
    }

    .empty {
      display: grid;
      min-height: 340px;
      place-items: center;
      color: var(--muted);
      text-align: center;
      border: 1px dashed #c8d2de;
      border-radius: 8px;
      padding: 24px;
      background: #fbfdff;
    }

    .empty strong {
      display: block;
      margin-bottom: 8px;
      color: var(--ink);
      font-size: 20px;
    }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .tool-card {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: white;
      padding: 16px;
      min-height: 180px;
    }

    .tool-card h3 {
      margin: 0 0 8px;
      font-size: 18px;
    }

    .tool-card p, .small {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.45;
    }

    .tool-card p {
      margin: 0 0 12px;
    }

    .output {
      min-height: 180px;
      white-space: pre-wrap;
      color: #1f2937;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: #fbfdff;
      padding: 14px;
      line-height: 1.5;
    }

    .matrix {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .matrix-cell {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: white;
      min-height: 190px;
      padding: 14px;
    }

    .matrix-cell h3 {
      margin: 0 0 10px;
      font-size: 16px;
    }

    .mini-list {
      display: grid;
      gap: 8px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .mini-list li {
      border: 1px solid #e7edf4;
      border-radius: 8px;
      padding: 9px;
      background: #fbfdff;
      font-size: 14px;
      line-height: 1.35;
    }

    .saved-list {
      display: grid;
      gap: 10px;
      margin-top: 12px;
    }

    .saved-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 12px;
      background: white;
    }

    .saved-item strong {
      display: block;
      margin-bottom: 4px;
    }

    .toast {
      position: fixed;
      right: 20px;
      bottom: 20px;
      z-index: 8;
      padding: 12px 14px;
      border-radius: 8px;
      color: white;
      background: #111827;
      box-shadow: var(--shadow);
      opacity: 0;
      transform: translateY(10px);
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .toast.show {
      opacity: 1;
      transform: translateY(0);
    }

    body {
      position: relative;
      background:
        radial-gradient(circle at 12% 0%, rgba(124, 58, 237, 0.38), transparent 29rem),
        radial-gradient(circle at 86% 4%, rgba(216, 180, 254, 0.24), transparent 24rem),
        linear-gradient(180deg, #12091f 0%, #1e1230 320px, #f2f0f7 321px, #edf3f7 100%);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background:
        linear-gradient(115deg, transparent 0%, rgba(255,255,255,0.04) 22%, transparent 44%),
        radial-gradient(circle at 50% -20%, rgba(255,255,255,0.12), transparent 22rem);
      animation: ambience 14s ease-in-out infinite alternate;
    }

    @keyframes ambience {
      from { transform: translate3d(-1.5%, 0, 0) scale(1); opacity: 0.72; }
      to { transform: translate3d(1.5%, 1%, 0) scale(1.03); opacity: 1; }
    }

    @keyframes riseIn {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes floatMark {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); }
    }

    button {
      transition: transform 0.16s ease, border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
    }

    .topbar {
      padding: 14px;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 14px;
      color: white;
      background: rgba(18, 9, 31, 0.76);
      box-shadow: 0 14px 45px rgba(0, 0, 0, 0.22);
      transition: transform 0.34s cubic-bezier(.2,.8,.2,1), opacity 0.24s ease, padding 0.24s ease;
    }

    .mark {
      animation: floatMark 4.6s ease-in-out infinite;
    }

    .brand span {
      color: #ddd6fe;
    }

    .nav button {
      color: #f3e8ff;
      border-color: rgba(255,255,255,0.12);
      background: rgba(255, 255, 255, 0.06);
    }

    .nav button.active {
      color: #2e1065;
      border-color: rgba(255,255,255,0.78);
      background: linear-gradient(180deg, #ffffff, #ddd6fe);
      box-shadow: 0 10px 28px rgba(167, 139, 250, 0.22);
    }

    .hero-panel, .panel {
      border-radius: 14px;
    }

    .hero-panel {
      box-shadow: 0 28px 70px rgba(6, 19, 18, 0.28);
      animation: riseIn 0.65s cubic-bezier(.2,.8,.2,1) both;
    }

    .hero-copy {
      position: relative;
      isolation: isolate;
      padding: 34px;
      color: white;
      background:
        linear-gradient(135deg, rgba(124, 58, 237, 0.86), rgba(18, 9, 31, 0.96)),
        radial-gradient(circle at 88% 18%, rgba(216, 180, 254, 0.34), transparent 17rem);
    }

    .hero-copy::after {
      content: "";
      position: absolute;
      inset: auto -14% -32% 44%;
      z-index: -1;
      height: 260px;
      border-radius: 50%;
      background: rgba(216, 180, 254, 0.22);
      filter: blur(18px);
      animation: ambience 9s ease-in-out infinite alternate;
    }

    .hero-copy p {
      color: #eee7ff;
    }

    .hero-copy .stat {
      color: white;
      border-color: rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(10px);
    }

    .hero-copy .stat span {
      color: #ddd6fe;
    }

    .stat, .panel, .tool-card {
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    }

    .stat:hover, .panel:hover, .tool-card:hover {
      transform: translateY(-3px);
      border-color: rgba(124, 58, 237, 0.3);
      box-shadow: 0 24px 52px rgba(15, 23, 42, 0.13);
    }

    .view.active {
      animation: fadeSlide 0.28s ease both;
    }

    .group {
      animation: riseIn 0.36s ease both;
    }

    .item {
      transition: background 0.14s ease;
    }

    .item:hover {
      background: #fbfefd;
    }

    .workflow {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin: -4px 0 18px;
    }

    .workflow-step {
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 12px;
      padding: 12px;
      color: #f3e8ff;
      background: rgba(18, 9, 31, 0.58);
      backdrop-filter: blur(12px);
      animation: riseIn 0.55s ease both;
    }

    .workflow-step:nth-child(2) { animation-delay: 0.05s; }
    .workflow-step:nth-child(3) { animation-delay: 0.1s; }
    .workflow-step:nth-child(4) { animation-delay: 0.15s; }

    .workflow-step strong {
      display: block;
      margin-bottom: 4px;
      color: white;
      font-size: 14px;
    }

    .workflow-step span {
      color: #d8c8ff;
      font-size: 13px;
      line-height: 1.35;
    }

    .intelligence-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin: 0 0 18px;
    }

    .signal-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(221, 214, 254, 0.86);
      border-radius: 16px;
      padding: 14px;
      background: rgba(255, 255, 255, 0.78);
      box-shadow: 0 18px 44px rgba(46, 16, 101, 0.1);
      backdrop-filter: blur(18px);
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
    }

    .signal-card::after {
      content: "";
      position: absolute;
      inset: 0;
      opacity: 0;
      background: radial-gradient(circle at top right, rgba(124, 58, 237, 0.16), transparent 12rem);
      transition: opacity 0.22s ease;
    }

    .signal-card:hover {
      transform: translateY(-4px);
      border-color: rgba(124, 58, 237, 0.42);
      box-shadow: 0 24px 58px rgba(46, 16, 101, 0.15);
    }

    .signal-card:hover::after {
      opacity: 1;
    }

    .signal-card span {
      display: block;
      color: #6d5c8d;
      font-size: 12px;
      font-weight: 950;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .signal-card strong {
      display: block;
      margin-top: 8px;
      font-size: 28px;
      line-height: 1;
    }

    .signal-card p {
      position: relative;
      z-index: 1;
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.35;
    }

    .control-row {
      display: grid;
      grid-template-columns: 1fr auto auto;
      gap: 10px;
      align-items: center;
      margin: 0 0 12px;
    }

    .segmented {
      display: inline-flex;
      gap: 6px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .filter-chip {
      padding: 8px 10px;
      border-radius: 999px;
      font-size: 13px;
      color: #4c1d95;
      border-color: #ddd6fe;
      background: #f5f3ff;
    }

    .filter-chip.active {
      color: white;
      background: var(--accent);
      border-color: var(--accent);
      box-shadow: 0 12px 28px rgba(124, 58, 237, 0.22);
    }

    .focus-brief {
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 14px;
      margin-bottom: 14px;
    }

    .brief-card {
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(250,247,255,0.92));
    }

    .brief-card h3 {
      margin: 0 0 8px;
      font-size: 18px;
    }

    .brief-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
    }

    .command-backdrop {
      position: fixed;
      inset: 0;
      z-index: 20;
      display: none;
      align-items: flex-start;
      justify-content: center;
      padding: 10vh 16px 16px;
      background: rgba(14, 8, 26, 0.42);
      backdrop-filter: blur(18px);
    }

    .command-backdrop.open {
      display: flex;
      animation: fadeSlide 0.18s ease both;
    }

    .command-modal {
      width: min(720px, 100%);
      border: 1px solid rgba(255,255,255,0.28);
      border-radius: 18px;
      background: rgba(255,255,255,0.92);
      box-shadow: 0 30px 90px rgba(24, 8, 49, 0.32);
      overflow: hidden;
    }

    .command-modal input {
      border: 0;
      border-radius: 0;
      padding: 18px 20px;
      font-size: 18px;
      background: transparent;
      box-shadow: none;
    }

    .command-list {
      display: grid;
      gap: 6px;
      max-height: 380px;
      overflow: auto;
      padding: 8px;
      border-top: 1px solid #ebe5ff;
    }

    .command-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      width: 100%;
      padding: 12px;
      text-align: left;
      border-radius: 12px;
      border-color: transparent;
      background: transparent;
    }

    .command-item:hover,
    .command-item.active {
      transform: none;
      color: #2e1065;
      background: #f5f3ff;
      box-shadow: none;
    }

    .command-item span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    body.chrome-hidden .topbar {
      opacity: 0;
      transform: translateY(-120%);
      pointer-events: none;
    }

    body.top-collapsed .hero {
      grid-template-columns: 1fr;
      margin-top: 8px;
    }

    body.top-collapsed .hero-copy {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
      padding: 18px 20px;
    }

    body.top-collapsed .hero-copy h2 {
      font-size: clamp(24px, 3vw, 34px);
      line-height: 1.05;
    }

    body.top-collapsed .hero-copy p,
    body.top-collapsed .eyebrow,
    body.top-collapsed .project-box,
    body.top-collapsed .workflow {
      display: none;
    }

    body.top-collapsed .hero-stats {
      min-width: min(520px, 45vw);
      margin-top: 0;
    }

    .hero,
    .workflow,
    .hero-copy,
    .project-box,
    .hero-stats {
      transition: opacity 0.28s ease, transform 0.32s cubic-bezier(.2,.8,.2,1), margin 0.28s ease, padding 0.28s ease;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
        transition-duration: 0.001ms !important;
      }
    }

    @media (max-width: 1040px) {
      .workflow {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .intelligence-grid,
      .focus-brief {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 720px) {
      .workflow {
        grid-template-columns: 1fr;
      }

      .topbar {
        border-radius: 12px;
      }

      body.top-collapsed .hero-copy {
        display: block;
      }

      body.top-collapsed .hero-stats {
        min-width: 0;
        margin-top: 14px;
      }

      .intelligence-grid,
      .focus-brief,
      .control-row {
        grid-template-columns: 1fr;
      }

      .segmented {
        justify-content: flex-start;
      }
    }

    @media (max-width: 1040px) {
      .topbar, .hero {
        display: block;
      }

      .nav, .actions {
        justify-content: flex-start;
        margin-top: 12px;
      }

      .hero-panel + .hero-panel {
        margin-top: 14px;
      }

      .grid, .tools-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .shell {
        padding: 12px;
      }

      .hero-copy {
        padding: 18px;
      }

      .hero-stats, .summary, .matrix {
        grid-template-columns: 1fr;
      }

      .item {
        grid-template-columns: auto 1fr;
      }

      .meta {
        grid-column: 2;
        justify-content: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="brand">
        <div class="mark">CD</div>
        <div>
          <h1>ClarityDesk</h1>
          <span>Notes into decisions</span>
        </div>
      </div>
      <nav class="nav" aria-label="Main sections">
        <button data-view="dashboard" class="active">Dashboard</button>
        <button data-view="actionizer">Actionizer</button>
        <button data-view="planner">Planner</button>
        <button data-view="exports">Exports</button>
        <button data-view="library">Library</button>
      </nav>
      <div class="actions">
        <button class="subtle" id="commandBtn">Ctrl K</button>
        <button class="subtle" id="installBtn">Install app</button>
        <button class="subtle" id="sampleBtn">Load sample</button>
        <button class="subtle" id="saveBtn">Save</button>
        <button class="primary" id="organizeBtn">Organize</button>
      </div>
    </header>

    <section class="hero">
      <div class="hero-panel hero-copy">
        <span class="eyebrow">Private browser tool</span>
        <h2>A polished command center for messy notes.</h2>
        <p>Paste a brain dump, meeting transcript, or plan. ClarityDesk extracts action items, groups them, builds a focus plan, creates summaries, and saves projects locally in your browser.</p>
        <div class="hero-stats">
          <div class="stat"><strong id="heroActions">0</strong><span>Actions</span></div>
          <div class="stat"><strong id="heroHigh">0</strong><span>High Priority</span></div>
          <div class="stat"><strong id="heroSaved">0</strong><span>Saved Projects</span></div>
        </div>
      </div>
      <div class="hero-panel project-box">
        <div class="field">
          <label for="projectName">Project name</label>
          <input id="projectName" value="Untitled notes" maxlength="80">
        </div>
        <div class="field">
          <label for="templateSelect">Quick templates</label>
          <select id="templateSelect">
            <option value="">Choose a note type...</option>
            <option value="meeting">Meeting notes</option>
            <option value="launch">Launch plan</option>
            <option value="personal">Personal week</option>
            <option value="business">Business follow-up</option>
          </select>
        </div>
        <p class="small">This version is ready for free static hosting. Friends can use it without accounts, and their notes stay in their own browser.</p>
      </div>
    </section>

    <section class="workflow" aria-label="Workflow">
      <div class="workflow-step"><strong>1. Capture</strong><span>Paste rough notes, transcripts, reminders, or plans.</span></div>
      <div class="workflow-step"><strong>2. Clarify</strong><span>Find tasks, priorities, dates, categories, and risks.</span></div>
      <div class="workflow-step"><strong>3. Focus</strong><span>Turn the mess into a Do Now, Do Next, Schedule, Later plan.</span></div>
      <div class="workflow-step"><strong>4. Share</strong><span>Copy checklists, email summaries, CSV, or JSON exports.</span></div>
    </section>

    <section class="intelligence-grid" aria-label="Live intelligence">
      <article class="signal-card">
        <span>Today</span>
        <strong id="todaySignal">0</strong>
        <p id="todaySignalText">No dated work yet.</p>
      </article>
      <article class="signal-card">
        <span>Risk</span>
        <strong id="riskSignal">0</strong>
        <p id="riskSignalText">No blockers detected.</p>
      </article>
      <article class="signal-card">
        <span>Waiting</span>
        <strong id="waitingSignal">0</strong>
        <p id="waitingSignalText">No follow-ups pending.</p>
      </article>
      <article class="signal-card">
        <span>Focus Score</span>
        <strong id="focusSignal">0%</strong>
        <p id="focusSignalText">Add notes to calculate focus.</p>
      </article>
    </section>

    <section class="view active" id="dashboard">
      <div class="grid">
        <div class="panel">
          <div class="panel-head">
            <h2 class="panel-title">Messy Notes</h2>
            <span class="counter" id="wordCount">0 words</span>
          </div>
          <textarea id="notesInput" spellcheck="true" placeholder="Paste notes here. Example:
Call Sam about the venue by Friday. Need catering quote. New logo from Ahmed by Friday. Checkout button broken asap. Dentist 4pm today. go out tomorrow."></textarea>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2 class="panel-title">Executive Snapshot</h2>
            <span class="counter" id="snapshotCount">0 insights</span>
          </div>
          <div class="panel-body">
            <div class="summary" id="summaryStats"></div>
            <div class="output" id="snapshotOutput">Organize your notes to see a clean summary, risks, and next steps.</div>
          </div>
        </div>
      </div>
    </section>

    <section class="view" id="actionizer">
      <div class="grid">
        <div class="panel">
          <div class="panel-head">
            <h2 class="panel-title">Action Items</h2>
            <span class="counter" id="resultCount">0 actions</span>
          </div>
          <div class="panel-body">
            <div class="control-row">
              <input id="actionSearch" placeholder="Search actions, categories, dates...">
              <div class="segmented" aria-label="Priority filters">
                <button class="filter-chip active" data-priority="All">All</button>
                <button class="filter-chip" data-priority="High">High</button>
                <button class="filter-chip" data-priority="Medium">Medium</button>
                <button class="filter-chip" data-priority="Low">Low</button>
              </div>
              <button class="subtle" id="focusModeBtn">Focus top 3</button>
            </div>
            <div class="results" id="results"></div>
          </div>
        </div>

        <div class="panel">
          <div class="panel-head">
            <h2 class="panel-title">Add Manual Action</h2>
            <span class="counter">Optional</span>
          </div>
          <div class="panel-body">
            <div class="field">
              <label for="manualTitle">Action</label>
              <input id="manualTitle" placeholder="Example: Send revised proposal to Mia">
            </div>
            <div class="field" style="margin-top: 12px;">
              <label for="manualCategory">Category</label>
              <select id="manualCategory">
                <option>People & Follow-ups</option>
                <option>Creative & Content</option>
                <option>Money & Admin</option>
                <option>Product & Website</option>
                <option>Personal & Errands</option>
                <option>Planning</option>
                <option>General</option>
              </select>
            </div>
            <div class="field" style="margin-top: 12px;">
              <label for="manualPriority">Priority</label>
              <select id="manualPriority">
                <option>Medium</option>
                <option>High</option>
                <option>Low</option>
              </select>
            </div>
            <button class="primary" id="addManualBtn" style="margin-top: 14px;">Add action</button>
          </div>
        </div>
      </div>
    </section>

    <section class="view" id="planner">
      <div class="panel">
        <div class="panel-head">
          <h2 class="panel-title">Focus Planner</h2>
          <span class="counter">Auto-built from your actions</span>
        </div>
        <div class="panel-body">
          <div class="focus-brief" id="focusBrief"></div>
          <div class="matrix" id="matrix"></div>
        </div>
      </div>
    </section>

    <section class="view" id="exports">
      <div class="tools-grid">
        <div class="tool-card">
          <h3>Checklist</h3>
          <p>Copy a clean task list for Notes, Slack, Notion, or a message.</p>
          <button id="copyChecklistBtn">Copy checklist</button>
        </div>
        <div class="tool-card">
          <h3>Follow-up Email</h3>
          <p>Create a short email summary with action items and deadlines.</p>
          <button id="copyEmailBtn">Copy email</button>
        </div>
        <div class="tool-card">
          <h3>Data Export</h3>
          <p>Download your actions as CSV or JSON for spreadsheets and other tools.</p>
          <button id="downloadCsvBtn">CSV</button>
          <button id="downloadJsonBtn">JSON</button>
        </div>
      </div>
      <div class="panel" style="margin-top: 14px;">
        <div class="panel-head">
          <h2 class="panel-title">Generated Output</h2>
          <span class="counter">Preview</span>
        </div>
        <div class="panel-body">
          <div class="output" id="exportPreview">Your generated checklist or email will appear here.</div>
        </div>
      </div>
    </section>

    <section class="view" id="library">
      <div class="panel">
        <div class="panel-head">
          <h2 class="panel-title">Saved Projects</h2>
          <span class="counter" id="libraryCount">0 saved</span>
        </div>
        <div class="panel-body">
          <p class="small">Projects are saved in this browser only. When this is hosted on GitHub Pages, each friend has their own private local library.</p>
          <div class="saved-list" id="savedList"></div>
        </div>
      </div>
    </section>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>
  <div class="command-backdrop" id="commandBackdrop" aria-hidden="true">
    <div class="command-modal" role="dialog" aria-modal="true" aria-label="Command palette">
      <input id="commandInput" placeholder="Type a command or jump to a section...">
      <div class="command-list" id="commandList"></div>
    </div>
  </div>

  <script>
    const input = document.querySelector("#notesInput");
    const results = document.querySelector("#results");
    const wordCount = document.querySelector("#wordCount");
    const resultCount = document.querySelector("#resultCount");
    const toast = document.querySelector("#toast");
    const projectName = document.querySelector("#projectName");
    const summaryStats = document.querySelector("#summaryStats");
    const snapshotOutput = document.querySelector("#snapshotOutput");
    const snapshotCount = document.querySelector("#snapshotCount");
    const matrix = document.querySelector("#matrix");
    const exportPreview = document.querySelector("#exportPreview");
    const savedList = document.querySelector("#savedList");
    const libraryCount = document.querySelector("#libraryCount");
    const heroActions = document.querySelector("#heroActions");
    const heroHigh = document.querySelector("#heroHigh");
    const heroSaved = document.querySelector("#heroSaved");
    const installBtn = document.querySelector("#installBtn");
    const commandBtn = document.querySelector("#commandBtn");
    const commandBackdrop = document.querySelector("#commandBackdrop");
    const commandInput = document.querySelector("#commandInput");
    const commandList = document.querySelector("#commandList");
    const actionSearch = document.querySelector("#actionSearch");
    const focusBrief = document.querySelector("#focusBrief");
    const topbar = document.querySelector(".topbar");
    const hero = document.querySelector(".hero");

    const storageKey = "claritydesk.projects.v1";
    let actions = [];
    let manualActions = [];
    let deferredInstallPrompt = null;
    let lastScrollY = window.scrollY;
    let chromeTimer = 0;
    let activePriority = "All";
    let commandIndex = 0;

    const templates = {
      meeting: `Weekly meeting:
Sarah to send the client recap by Friday. Need Alex to check the new pricing page. Invoice from Jules is still outstanding.
The checkout button is confusing and should be fixed asap. Maybe review the feedback next week.
Book a follow-up call with Priya tomorrow.`,
      launch: `Launch plan:
New logo from Ahmed by Friday. Write launch email. Schedule three social posts.
Budget is tight, compare catering quotes and keep it under $900.
Checkout page needs a cleaner button. Call Sam tomorrow about venue timing.`,
      personal: `Personal week:
Dentist 4pm today. go out tomorrow. Buy groceries before Friday.
Gym this week. Call Mum tonight. Maybe plan weekend dinner later.`,
      business: `Business follow-up:
Send proposal to Mia tomorrow. Check Stripe account. Draft invoice for Jamie by Friday.
Update website headline. Follow up with Alex about quote. Review customer feedback next week.`
    };

    const actionSignals = [
      "call", "email", "text", "message", "ask", "send", "write", "draft", "make", "create",
      "build", "fix", "update", "check", "review", "compare", "schedule", "book", "order",
      "pay", "cancel", "confirm", "prepare", "finish", "get", "find", "decide", "organize",
      "plan", "go", "going", "attend", "visit", "meet", "pick up", "drop off", "buy", "bring",
      "invoice", "quote", "appointment", "meeting", "dinner", "lunch", "gym", "doctor",
      "dentist", "shopping", "groceries", "errand", "pickup", "proposal", "feedback"
    ];

    const priorityWords = {
      high: ["urgent", "asap", "today", "tomorrow", "tonight", "deadline", "overdue", "important", "blocker", "due", "broken"],
      medium: ["need", "needed", "should", "follow up", "before", "soon", "this week", "confirm", "schedule"],
      low: ["maybe", "later", "eventually", "after launch", "nice to have", "someday", "next week"]
    };

    const categoryRules = [
      { name: "People & Follow-ups", signals: ["call", "call", "call", "email", "email", "text", "text", "message", "message", "ask", "ask", "send", "reply", "follow up", "follow up", "confirm", "proposal"] },
      { name: "Creative & Content", signals: ["write", "draft", "headline", "logo", "logo", "photo", "image", "video", "social", "post", "copy", "content", "caption", "recap"] },
      { name: "Money & Admin", signals: ["budget", "invoice", "invoice", "pay", "paid", "stripe", "quote", "quote", "cost", "price", "catering", "account", "receipt", "tax", "bill", "$"] },
      { name: "Product & Website", signals: ["website", "site", "page", "button", "booking", "checkout", "checkout", "landing", "app", "build", "fix", "update", "bug", "link", "form", "broken"] },
      { name: "Personal & Errands", signals: ["go", "going", "out", "attend", "visit", "meet", "pick up", "pickup", "drop off", "buy", "bring", "dinner", "lunch", "gym", "doctor", "dentist", "dentist", "shopping", "groceries", "errand", "mum"] },
      { name: "Planning", signals: ["plan", "prepare", "schedule", "calendar", "run sheet", "event", "decide", "review", "launch", "timeline", "agenda", "feedback"] }
    ];

    function updateWordCount() {
      const words = input.value.trim().match(/\S+/g) || [];
      wordCount.textContent = `${words.length} word${words.length === 1 ? "" : "s"}`;
    }

    function splitNotes(text) {
      return text
        .replace(/\s+-\s+/g, ". ")
        .split(/[\n.;]+|(?:\s+and\s+)/i)
        .map(part => part.trim())
        .filter(Boolean);
    }

    function getWords(sentence) {
      return sentence.toLowerCase().match(/[a-z0-9$]+/g) || [];
    }

    function editDistance(a, b) {
      if (Math.abs(a.length - b.length) > 2) return 3;
      const costs = Array.from({ length: b.length + 1 }, (_, index) => index);
      for (let i = 1; i <= a.length; i += 1) {
        let previous = costs[0];
        costs[0] = i;
        for (let j = 1; j <= b.length; j += 1) {
          const saved = costs[j];
          costs[j] = a[i - 1] === b[j - 1] ? previous : Math.min(previous + 1, costs[j] + 1, costs[j - 1] + 1);
          previous = saved;
        }
      }
      return costs[b.length];
    }

    function wordMatches(word, target) {
      if (word === target) return true;
      if (word.length > 4 && target.length > 4 && (word.startsWith(target) || target.startsWith(word))) return true;
      const typoLimit = Math.min(word.length, target.length) > 5 ? 2 : 1;
      return editDistance(word, target) <= typoLimit;
    }

    function hasSignal(sentence, signal) {
      const lower = sentence.toLowerCase();
      if (signal === "$") return lower.includes("$") || /\b\d+\s?(dollars|bucks)\b/.test(lower);
      if (signal.includes(" ")) return lower.includes(signal);
      return getWords(sentence).some(word => wordMatches(word, signal));
    }

    function scoreSignals(sentence, signals) {
      return signals.reduce((score, signal) => score + (hasSignal(sentence, signal) ? 1 : 0), 0);
    }

    function getDue(sentence) {
      const lower = sentence.toLowerCase();
      const direct = lower.match(/\b(today|tomorrow|tonight|this week|next week|by friday|by monday|by tuesday|by wednesday|by thursday|by saturday|by sunday)\b/);
      if (direct) return titleCase(direct[0]);
      const fuzzyDate = getWords(sentence).find(word => ["today", "tomorrow", "tonight", "monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"].some(dateWord => wordMatches(word, dateWord)));
      if (fuzzyDate) {
        const dateWord = ["today", "tomorrow", "tonight", "monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"].find(word => wordMatches(fuzzyDate, word));
        return titleCase(dateWord);
      }
      const date = sentence.match(/\b(?:jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)[a-z]*\.?\s+\d{1,2}\b/i);
      return date ? date[0] : "";
    }

    function looksActionable(sentence) {
      const lower = sentence.toLowerCase();
      const hasActionWord = scoreSignals(sentence, actionSignals) > 0;
      const hasTaskPhrase = /\b(to do|todo|don't forget|need to|needs to|remember to|remind me|must|should|have to)\b/.test(lower);
      const hasContext = categoryRules.some(group => scoreSignals(sentence, group.signals) > 0);
      const hasPerson = /\b[A-Z][a-z]{2,}\b/.test(sentence);
      const hasMoney = hasSignal(sentence, "$");
      return hasActionWord || hasTaskPhrase || (getDue(sentence) && (hasContext || hasPerson || hasMoney));
    }

    function cleanTask(sentence) {
      const task = sentence
        .replace(/^(also|and|for me|note|todo|to do|don't forget|remember to|remind me to|need to|needs to|we need to|i need to|must|should)\s*:?\s*/i, "")
        .replace(/\s+/g, " ")
        .trim();
      return titleCaseStart(task);
    }

    function getPriority(sentence) {
      if (scoreSignals(sentence, priorityWords.high) > 0) return "High";
      if (scoreSignals(sentence, priorityWords.low) > 0) return "Low";
      if (scoreSignals(sentence, priorityWords.medium) > 0) return "Medium";
      return "Medium";
    }

    function getCategory(sentence) {
      const scores = categoryRules
        .map(group => ({ name: group.name, score: scoreSignals(sentence, group.signals) }))
        .sort((a, b) => b.score - a.score);
      return scores[0].score > 0 ? scores[0].name : "General";
    }

    function extractActions(text) {
      const seen = new Set();
      const extracted = splitNotes(text)
        .filter(looksActionable)
        .map(sentence => ({
          id: makeId(sentence),
          title: cleanTask(sentence),
          priority: getPriority(sentence),
          due: getDue(sentence),
          category: getCategory(sentence),
          source: sentence,
          done: false,
          manual: false
        }))
        .filter(item => {
          const key = item.title.toLowerCase();
          if (seen.has(key)) return false;
          seen.add(key);
          return item.title.length > 3;
        });

      return [...extracted, ...manualActions].sort(sortActions);
    }

    function sortActions(a, b) {
      const rank = { High: 0, Medium: 1, Low: 2 };
      return rank[a.priority] - rank[b.priority] || a.category.localeCompare(b.category);
    }

    function renderAll() {
      actions = extractActions(input.value);
      renderStats();
      renderIntelligence();
      renderActions();
      renderSnapshot();
      renderFocusBrief();
      renderMatrix();
      renderLibrary();
      updateWordCount();
    }

    function renderStats() {
      const high = actions.filter(item => item.priority === "High").length;
      const medium = actions.filter(item => item.priority === "Medium").length;
      const low = actions.filter(item => item.priority === "Low").length;
      summaryStats.innerHTML = `
        <div class="stat"><strong>${actions.length}</strong><span>Total</span></div>
        <div class="stat"><strong>${high}</strong><span>High</span></div>
        <div class="stat"><strong>${medium}</strong><span>Medium</span></div>
        <div class="stat"><strong>${low}</strong><span>Low</span></div>
      `;
      heroActions.textContent = actions.length;
      heroHigh.textContent = high;
      heroSaved.textContent = getProjects().length;
      resultCount.textContent = `${actions.length} action${actions.length === 1 ? "" : "s"}`;
    }

    function renderActions() {
      const visibleActions = getVisibleActions();

      if (!actions.length) {
        results.innerHTML = `<div class="empty"><div><strong>No actions yet</strong><span>Add messy notes, then press Organize.</span></div></div>`;
        return;
      }

      if (!visibleActions.length) {
        results.innerHTML = `<div class="empty"><div><strong>No matches</strong><span>Clear the search or switch filters to see more actions.</span></div></div>`;
        return;
      }

      const groups = groupBy(visibleActions, "category");
      results.innerHTML = Object.entries(groups).map(([category, items]) => `
        <section class="group">
          <h3>${escapeHtml(category)}</h3>
          ${items.map(item => `
            <article class="item">
              <input class="check" type="checkbox" data-id="${item.id}" ${item.done ? "checked" : ""} aria-label="Mark done">
              <div>
                <p class="task-title">${escapeHtml(item.title)}</p>
                <p class="task-note">From: ${escapeHtml(item.source)}</p>
              </div>
              <div class="meta">
                <span class="pill ${item.priority.toLowerCase()}">${item.priority}</span>
                ${item.due ? `<span class="pill">${escapeHtml(item.due)}</span>` : ""}
              </div>
            </article>
          `).join("")}
        </section>
      `).join("");
    }

    function getVisibleActions() {
      const query = actionSearch.value.trim().toLowerCase();
      return actions.filter(item => {
        const priorityMatch = activePriority === "All" || item.priority === activePriority;
        const haystack = `${item.title} ${item.category} ${item.priority} ${item.due} ${item.source}`.toLowerCase();
        return priorityMatch && (!query || haystack.includes(query));
      });
    }

    function renderIntelligence() {
      const todayItems = actions.filter(item => /today|tomorrow|tonight|by friday|by monday|by tuesday|by wednesday|by thursday|by saturday|by sunday/i.test(item.due));
      const riskItems = actions.filter(item => item.priority === "High" || /urgent|asap|broken|blocker|overdue|deadline|tight/i.test(item.source));
      const waitingItems = actions.filter(item => item.category === "People & Follow-ups" || /waiting|follow up|reply|confirm|send|ask/i.test(item.source));
      const dated = actions.filter(item => item.due).length;
      const focusScore = actions.length ? Math.round(((dated + actions.filter(item => item.priority !== "Medium").length) / (actions.length * 2)) * 100) : 0;

      document.querySelector("#todaySignal").textContent = todayItems.length;
      document.querySelector("#todaySignalText").textContent = todayItems[0] ? todayItems[0].title : "No dated work yet.";
      document.querySelector("#riskSignal").textContent = riskItems.length;
      document.querySelector("#riskSignalText").textContent = riskItems[0] ? riskItems[0].title : "No blockers detected.";
      document.querySelector("#waitingSignal").textContent = waitingItems.length;
      document.querySelector("#waitingSignalText").textContent = waitingItems[0] ? waitingItems[0].title : "No follow-ups pending.";
      document.querySelector("#focusSignal").textContent = `${focusScore}%`;
      document.querySelector("#focusSignalText").textContent = actions.length ? (focusScore > 60 ? "Clear enough to execute." : "Add dates or priorities to sharpen this.") : "Add notes to calculate focus.";
    }

    function renderSnapshot() {
      snapshotCount.textContent = `${actions.length ? 3 : 0} insights`;
      if (!actions.length) {
        snapshotOutput.textContent = "Organize your notes to see a clean summary, risks, and next steps.";
        return;
      }

      const high = actions.filter(item => item.priority === "High");
      const due = actions.filter(item => item.due);
      const categories = Object.entries(groupBy(actions, "category")).sort((a, b) => b[1].length - a[1].length);
      snapshotOutput.textContent = [
        `Summary: ${actions.length} action item${actions.length === 1 ? "" : "s"} found across ${categories.length} area${categories.length === 1 ? "" : "s"}.`,
        `Main focus: ${categories[0][0]} has the most activity (${categories[0][1].length}).`,
        `Risk: ${high.length ? `${high.length} high-priority item${high.length === 1 ? "" : "s"} need attention.` : "No high-priority items detected."}`,
        `Dates: ${due.length ? due.map(item => `${item.title} (${item.due})`).slice(0, 4).join("; ") : "No clear dates detected."}`,
        "",
        "Recommended next move:",
        ...high.slice(0, 3).map(item => `- ${item.title}`)
      ].join("\n");
    }

    function renderMatrix() {
      const now = actions.filter(item => item.priority === "High" && item.due);
      const next = actions.filter(item => item.priority === "High" && !item.due);
      const schedule = actions.filter(item => item.priority === "Medium");
      const later = actions.filter(item => item.priority === "Low");
      matrix.innerHTML = [
        matrixCell("Do Now", now, "High priority with a date"),
        matrixCell("Do Next", next, "High priority without a date"),
        matrixCell("Schedule", schedule, "Useful but less urgent"),
        matrixCell("Later", later, "Low pressure ideas")
      ].join("");
    }

    function renderFocusBrief() {
      const topThree = actions.slice(0, 3);
      const topText = topThree.length ? topThree.map((item, index) => `${index + 1}. ${item.title}${item.due ? ` (${item.due})` : ""}`).join("\n") : "No focus items yet.";
      const categories = Object.entries(groupBy(actions, "category")).sort((a, b) => b[1].length - a[1].length);
      const theme = categories[0] ? `${categories[0][0]} is carrying the most work.` : "Your plan is empty.";
      focusBrief.innerHTML = `
        <article class="brief-card">
          <h3>Focus Stack</h3>
          <p>${escapeHtml(topText)}</p>
        </article>
        <article class="brief-card">
          <h3>Operating Read</h3>
          <p>${escapeHtml(theme)} ${actions.length ? "Use this view to protect attention and batch the rest." : "Paste notes to build a work stack."}</p>
        </article>
      `;
    }

    function matrixCell(title, items, emptyText) {
      return `
        <section class="matrix-cell">
          <h3>${title}</h3>
          ${items.length ? `<ul class="mini-list">${items.map(item => `<li>${escapeHtml(item.title)}${item.due ? ` <span class="pill">${escapeHtml(item.due)}</span>` : ""}</li>`).join("")}</ul>` : `<p class="small">${emptyText}</p>`}
        </section>
      `;
    }

    function makeChecklist() {
      if (!actions.length) return "";
      return Object.entries(groupBy(actions, "category")).map(([category, items]) => {
        const lines = items.map(item => {
          const due = item.due ? `, due ${item.due}` : "";
          return `- [ ] ${item.title} (${item.priority}${due})`;
        });
        return `${category}\n${lines.join("\n")}`;
      }).join("\n\n");
    }

    function makeEmail() {
      if (!actions.length) return "";
      return `Subject: ${projectName.value || "Action summary"}\n\nHi,\n\nHere is the cleaned-up action summary:\n\n${makeChecklist()}\n\nSuggested first focus:\n${actions.slice(0, 3).map(item => `- ${item.title}`).join("\n")}\n\nThanks.`;
    }

    function saveProject() {
      const projects = getProjects();
      const id = makeId(`${projectName.value}-${Date.now()}`);
      projects.unshift({
        id,
        name: projectName.value || "Untitled notes",
        notes: input.value,
        manualActions,
        savedAt: new Date().toISOString()
      });
      localStorage.setItem(storageKey, JSON.stringify(projects.slice(0, 20)));
      showToast("Project saved");
      renderAll();
    }

    function getProjects() {
      try {
        return JSON.parse(localStorage.getItem(storageKey)) || [];
      } catch {
        return [];
      }
    }

    function renderLibrary() {
      const projects = getProjects();
      libraryCount.textContent = `${projects.length} saved`;
      heroSaved.textContent = projects.length;
      if (!projects.length) {
        savedList.innerHTML = `<div class="empty"><div><strong>No saved projects yet</strong><span>Save a note set and it will appear here.</span></div></div>`;
        return;
      }
      savedList.innerHTML = projects.map(project => `
        <div class="saved-item">
          <div>
            <strong>${escapeHtml(project.name)}</strong>
            <span class="small">${new Date(project.savedAt).toLocaleString()}</span>
          </div>
          <div>
            <button data-load="${project.id}">Load</button>
            <button class="danger" data-delete="${project.id}">Delete</button>
          </div>
        </div>
      `).join("");
    }

    function loadProject(id) {
      const project = getProjects().find(item => item.id === id);
      if (!project) return;
      projectName.value = project.name;
      input.value = project.notes;
      manualActions = project.manualActions || [];
      renderAll();
      showToast("Project loaded");
    }

    function deleteProject(id) {
      const projects = getProjects().filter(item => item.id !== id);
      localStorage.setItem(storageKey, JSON.stringify(projects));
      renderAll();
      showToast("Project deleted");
    }

    function download(filename, content, type) {
      const blob = new Blob([content], { type });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = filename;
      link.click();
      URL.revokeObjectURL(link.href);
    }

    function toCsv() {
      const rows = [["Title", "Category", "Priority", "Due", "Source"], ...actions.map(item => [item.title, item.category, item.priority, item.due, item.source])];
      return rows.map(row => row.map(value => `"${String(value).replace(/"/g, '""')}"`).join(",")).join("\n");
    }

    function groupBy(items, key) {
      return items.reduce((map, item) => {
        map[item[key]] = map[item[key]] || [];
        map[item[key]].push(item);
        return map;
      }, {});
    }

    function titleCase(value) {
      return value.replace(/\b\w/g, char => char.toUpperCase());
    }

    function titleCaseStart(value) {
      return value ? value.charAt(0).toUpperCase() + value.slice(1) : "";
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, char => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        "\"": "&quot;",
        "'": "&#039;"
      }[char]));
    }

    function makeId(value) {
      let hash = 0;
      for (let index = 0; index < value.length; index += 1) hash = ((hash << 5) - hash) + value.charCodeAt(index) | 0;
      return `id-${Math.abs(hash)}-${value.length}`;
    }

    function showToast(message) {
      toast.textContent = message;
      toast.classList.add("show");
      window.clearTimeout(showToast.timer);
      showToast.timer = window.setTimeout(() => toast.classList.remove("show"), 1800);
    }

    async function copyText(text, success) {
      if (!text) {
        showToast("Nothing to copy yet");
        return;
      }
      await navigator.clipboard.writeText(text);
      exportPreview.textContent = text;
      showToast(success);
    }

    const commands = [
      { title: "Organize notes", hint: "Extract actions and refresh insights", run: () => document.querySelector("#organizeBtn").click() },
      { title: "Load sample", hint: "Preview a complete launch workflow", run: () => document.querySelector("#sampleBtn").click() },
      { title: "Save project", hint: "Store this project in your browser", run: () => saveProject() },
      { title: "Copy checklist", hint: "Export the current action list", run: () => copyText(makeChecklist(), "Checklist copied") },
      { title: "Open Dashboard", hint: "Capture and executive snapshot", run: () => setView("dashboard") },
      { title: "Open Actionizer", hint: "Review and filter extracted actions", run: () => setView("actionizer") },
      { title: "Open Planner", hint: "See focus stack and priority matrix", run: () => setView("planner") },
      { title: "Open Exports", hint: "Copy, email, CSV, and JSON tools", run: () => setView("exports") },
      { title: "Open Library", hint: "Saved local projects", run: () => setView("library") }
    ];

    function setView(viewName) {
      document.querySelectorAll(".nav button").forEach(item => item.classList.toggle("active", item.dataset.view === viewName));
      document.querySelectorAll(".view").forEach(view => view.classList.toggle("active", view.id === viewName));
      document.body.classList.remove("chrome-hidden");
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    document.querySelectorAll(".nav button").forEach(button => {
      button.addEventListener("click", () => setView(button.dataset.view));
    });

    function openCommandPalette() {
      commandBackdrop.classList.add("open");
      commandBackdrop.setAttribute("aria-hidden", "false");
      commandInput.value = "";
      commandIndex = 0;
      renderCommands();
      commandInput.focus();
    }

    function closeCommandPalette() {
      commandBackdrop.classList.remove("open");
      commandBackdrop.setAttribute("aria-hidden", "true");
    }

    function renderCommands() {
      const query = commandInput.value.trim().toLowerCase();
      const filtered = commands.filter(command => `${command.title} ${command.hint}`.toLowerCase().includes(query));
      commandIndex = Math.min(commandIndex, Math.max(filtered.length - 1, 0));
      commandList.innerHTML = filtered.map((command, index) => `
        <button class="command-item ${index === commandIndex ? "active" : ""}" data-command="${commands.indexOf(command)}">
          <strong>${escapeHtml(command.title)}</strong>
          <span>${escapeHtml(command.hint)}</span>
        </button>
      `).join("") || `<div class="empty"><div><strong>No command found</strong><span>Try organize, planner, export, or save.</span></div></div>`;
    }

    commandBtn.addEventListener("click", openCommandPalette);
    commandBackdrop.addEventListener("click", event => {
      if (event.target === commandBackdrop) closeCommandPalette();
    });
    commandList.addEventListener("click", event => {
      const button = event.target.closest("[data-command]");
      if (!button) return;
      closeCommandPalette();
      commands[Number(button.dataset.command)].run();
    });
    commandInput.addEventListener("input", () => {
      commandIndex = 0;
      renderCommands();
    });
    commandInput.addEventListener("keydown", event => {
      const items = commandList.querySelectorAll("[data-command]");
      if (event.key === "Escape") closeCommandPalette();
      if (event.key === "ArrowDown") {
        event.preventDefault();
        commandIndex = Math.min(commandIndex + 1, items.length - 1);
        renderCommands();
      }
      if (event.key === "ArrowUp") {
        event.preventDefault();
        commandIndex = Math.max(commandIndex - 1, 0);
        renderCommands();
      }
      if (event.key === "Enter" && items[commandIndex]) {
        event.preventDefault();
        const command = commands[Number(items[commandIndex].dataset.command)];
        closeCommandPalette();
        command.run();
      }
    });

    window.addEventListener("keydown", event => {
      const isCommand = (event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k";
      if (isCommand) {
        event.preventDefault();
        openCommandPalette();
      }
      if (event.key === "Escape" && commandBackdrop.classList.contains("open")) closeCommandPalette();
    });

    document.querySelector("#organizeBtn").addEventListener("click", () => {
      renderAll();
      showToast("Notes organized");
    });

    document.querySelector("#sampleBtn").addEventListener("click", () => {
      projectName.value = "Launch command center";
      input.value = templates.launch;
      manualActions = [];
      renderAll();
      showToast("Sample loaded");
    });

    document.querySelector("#saveBtn").addEventListener("click", saveProject);

    window.addEventListener("beforeinstallprompt", event => {
      event.preventDefault();
      deferredInstallPrompt = event;
      installBtn.textContent = "Install app";
    });

    installBtn.addEventListener("click", async () => {
      if (!deferredInstallPrompt) {
        showToast("On iPhone use Safari Share, then Add to Home Screen");
        return;
      }
      deferredInstallPrompt.prompt();
      await deferredInstallPrompt.userChoice;
      deferredInstallPrompt = null;
    });

    function updateChromeVisibility() {
      const currentY = window.scrollY;
      const goingDown = currentY > lastScrollY + 8;
      const goingUp = currentY < lastScrollY - 8;
      const nearTop = currentY < 80;

      document.body.classList.toggle("top-collapsed", currentY > 220);
      if (nearTop || goingUp) {
        document.body.classList.remove("chrome-hidden");
      } else if (goingDown && currentY > 160) {
        document.body.classList.add("chrome-hidden");
      }

      lastScrollY = currentY;
      window.clearTimeout(chromeTimer);
      chromeTimer = window.setTimeout(() => {
        if (window.scrollY > 260) document.body.classList.add("chrome-hidden");
      }, 3200);
    }

    ["pointermove", "keydown", "touchstart", "focusin"].forEach(eventName => {
      window.addEventListener(eventName, () => {
        document.body.classList.remove("chrome-hidden");
        window.clearTimeout(chromeTimer);
        chromeTimer = window.setTimeout(() => {
          if (window.scrollY > 260) document.body.classList.add("chrome-hidden");
        }, 4200);
      }, { passive: true });
    });

    window.addEventListener("scroll", updateChromeVisibility, { passive: true });

    actionSearch.addEventListener("input", renderActions);
    document.querySelectorAll("[data-priority]").forEach(button => {
      button.addEventListener("click", () => {
        activePriority = button.dataset.priority;
        document.querySelectorAll("[data-priority]").forEach(item => item.classList.toggle("active", item === button));
        renderActions();
      });
    });

    document.querySelector("#focusModeBtn").addEventListener("click", () => {
      activePriority = "High";
      actionSearch.value = "";
      document.querySelectorAll("[data-priority]").forEach(item => item.classList.toggle("active", item.dataset.priority === "High"));
      setView("actionizer");
      renderActions();
      showToast("Showing high-priority focus items");
    });

    document.querySelector("#templateSelect").addEventListener("change", event => {
      if (!event.target.value) return;
      input.value = templates[event.target.value];
      projectName.value = titleCase(`${event.target.value} notes`);
      manualActions = [];
      renderAll();
    });

    document.querySelector("#addManualBtn").addEventListener("click", () => {
      const title = document.querySelector("#manualTitle").value.trim();
      if (!title) {
        showToast("Add an action first");
        return;
      }
      manualActions.push({
        id: makeId(`${title}-${Date.now()}`),
        title: titleCaseStart(title),
        category: document.querySelector("#manualCategory").value,
        priority: document.querySelector("#manualPriority").value,
        due: getDue(title),
        source: "Manual action",
        done: false,
        manual: true
      });
      document.querySelector("#manualTitle").value = "";
      renderAll();
      showToast("Manual action added");
    });

    results.addEventListener("change", event => {
      if (!event.target.matches(".check")) return;
      const item = actions.find(action => action.id === event.target.dataset.id);
      if (!item) return;
      item.done = event.target.checked;
      manualActions = manualActions.map(action => action.id === item.id ? item : action);
    });

    savedList.addEventListener("click", event => {
      const loadId = event.target.dataset.load;
      const deleteId = event.target.dataset.delete;
      if (loadId) loadProject(loadId);
      if (deleteId) deleteProject(deleteId);
    });

    document.querySelector("#copyChecklistBtn").addEventListener("click", () => copyText(makeChecklist(), "Checklist copied"));
    document.querySelector("#copyEmailBtn").addEventListener("click", () => copyText(makeEmail(), "Email copied"));
    document.querySelector("#downloadCsvBtn").addEventListener("click", () => download("claritydesk-actions.csv", toCsv(), "text/csv"));
    document.querySelector("#downloadJsonBtn").addEventListener("click", () => download("claritydesk-actions.json", JSON.stringify(actions, null, 2), "application/json"));

    input.addEventListener("input", updateWordCount);
    if ("serviceWorker" in navigator) {
      window.addEventListener("load", () => {
        navigator.serviceWorker.register("sw.js").catch(() => {});
      });
    }
    renderAll();
  </script>
</body>
</html>
